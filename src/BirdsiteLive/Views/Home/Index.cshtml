@using BirdsiteLive.Controllers;
@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero-card">
    <p class="hero-eyebrow">ActivityPub bridge</p>
    <h1 class="hero-title">Follow @ViewData.Model.ServiceName accounts from the fediverse</h1>
    <p class="hero-lead">
        bird.makeup mirrors public @ViewData.Model.ServiceName accounts into ActivityPub.
        Enter a handle to open its profile page.
    </p>

    <form class="hero-form" method="POST">
        <input type="text" class="form-control hero-input" id="handle" name="handle" autocomplete="off" placeholder="@ViewData.Model.ServiceName handle" />
        <button type="submit" class="btn btn-primary hero-button">Show</button>
    </form>
</section>

<p class="home-note">
    bird.makeup is made by <a href="https://r.town/@@vincent">Vincent Cloutier</a>.
    Many thanks to Patreon supporters.
</p>
